# Copy this to .env and fill in the paths for your machine:
#   cp .env.example .env
#
# Then source it before building or running:
#   source .env

export MISAKI_VENV=        # path to your Python venv with misaki[en] installed
export PYO3_PYTHON=        # path to the venv's python binary
export DYLD_LIBRARY_PATH=  # run: $MISAKI_VENV/bin/python -c "import sysconfig; print(sysconfig.get_config_var('LIBDIR'))"
