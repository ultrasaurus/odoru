# Source this before building or running ko-odoru:
#   source .env
#
# These paths are machine-specific — do not commit this file.
 
export MISAKI_VENV=~/.misaki-g2p/venv
# export PYO3_PYTHON=~/.misaki-g2p/venv/bin/python
# export PYO3_PYTHON=/opt/homebrew/Cellar/python@3.12/3.12.12/Frameworks/Python.framework/Versions/3.12/bin/python3.12
export PYO3_PYTHON=/opt/homebrew/bin/python3.12
